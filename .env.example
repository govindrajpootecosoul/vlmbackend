PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/vlm_academy
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=30d
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
OTP_EXPIRY_MINUTES=10
OTP_MAX_RETRIES=5
POINTS_TO_INR_RATIO=10
MIN_WITHDRAWAL_AMOUNT=500
REQUEST_RESPONSE_TIMER_SEC=20
MAX_TEACHERS_PER_REQUEST=4

# Vercel production: set MONGODB_URI to Atlas URL and FRONTEND_URL to your Vercel frontend URL
